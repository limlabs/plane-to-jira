# Plane configuration
PLANE_BASE_URL=https://your-plane-instance.com
PLANE_API_TOKEN=your-plane-api-token
PLANE_WORKSPACE_SLUG=your-workspace-slug

# JIRA configuration
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token

# User mapping (Plane email → JIRA email, comma-separated)
# USER_MAP=plane-user@example.com=jira-user@example.com,another@plane.com=another@jira.com
